{
    "name": "mrdemonwolf/tailsignal",
    "description": "A self-hosted WordPress plugin using Expo to send custom push notifications.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "MrDemonWolf, Inc.",
            "homepage": "https://github.com/mrdemonwolf"
        }
    ],
    "require": {
        "php": ">=7.4",
        "ctwillie/expo-server-sdk-php": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "brain/monkey": "^2.6",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {}
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
